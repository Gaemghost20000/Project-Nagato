# LLM Gateway Configuration

# Specify the LLM provider: "openrouter" or "litellm"
LLM_PROVIDER="openrouter"

# OpenRouter Configuration (if LLM_PROVIDER is "openrouter")
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY_HERE"
OPENROUTER_API_BASE="https://openrouter.ai/api/v1"

# LiteLLM Configuration (if LLM_PROVIDER is "litellm")
# Ensure LiteLLM server is running and accessible at LITELLM_API_BASE
LITELLM_API_KEY="YOUR_LITELLM_API_KEY_HERE" # Or sk-..., or leave blank if not required by your LiteLLM setup
LITELLM_API_BASE="http://localhost:4000" # Example, adjust if your LiteLLM runs elsewhere

# Default model to use if not specified in the request
DEFAULT_MODEL_NAME="nousresearch/nous-capybara-7b-v1.9"

# Port for the llm-gateway service
PORT=3001